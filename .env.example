# ─────────────────────────────────────────────────────────────────────────────
# Ask Rani admin panel — environment contract (NO real values in this file)
# Copy to `.env.local` and fill in. `.env.local` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL.  Supabase dashboard → Project Settings → Data API.
# Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key.  Same settings page.
# Safe to expose to the browser — RLS is what protects data, not this key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key.  SERVER ONLY.
#   - NEVER prefix with NEXT_PUBLIC.
#   - NEVER import into a client component / browser bundle.
#   - Bypasses RLS. Used by server routes (order actions, agent-config render,
#     thread_messages/conversations writes, store_secrets access) and migration.
SUPABASE_SERVICE_ROLE_KEY=

# Google service-account JSON (single-line, server only).  Used by the
# agent-config "render to Drive" step. HUMAN TODO: create the service account
# and share each store's Drive folder (store_folder_id) with its email.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Stores Config Sheet id — consumed only by scripts/migrate-from-sheets.ts at
# runtime. Never hardcode a sheet id in source.
SHEET_STORES_CONFIG=1MOqS28V4UnWM7VyATWXIPV3KUsspJYwkrAusuvjFIxY
