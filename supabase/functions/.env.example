# Edge Function secrets. Copy to supabase/functions/.env for local `functions
# serve`; for deploy use `supabase secrets set`. (SUPABASE_URL /
# SUPABASE_SERVICE_ROLE_KEY are injected automatically.)

# A token you invent; must match what you enter in Meta's webhook config.
WA_VERIFY_TOKEN=

# Meta App Secret — used to verify the X-Hub-Signature-256 on inbound webhooks.
WA_APP_SECRET=
