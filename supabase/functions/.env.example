# Edge Function secrets. Copy to supabase/functions/.env for local `functions
# serve`; for deploy use `supabase secrets set`. (SUPABASE_URL /
# SUPABASE_SERVICE_ROLE_KEY are injected automatically.)

# A token you invent; must match what you enter in Meta's webhook config.
WA_VERIFY_TOKEN=

# Meta App Secret — used to verify the X-Hub-Signature-256 on inbound webhooks.
WA_APP_SECRET=

# Gemini AI Studio API key (https://aistudio.google.com). The bot's shared key,
# server-only — never in .env.local or any client bundle. Without it the bot
# logs inbound but sends no reply.
GEMINI_API_KEY=

# Optional model override (default: gemini-2.5-flash). 2.5 models support the
# implicit prompt caching this code is structured for.
GEMINI_MODEL=
