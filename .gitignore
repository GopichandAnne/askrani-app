# env files — NEVER commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example IS committed (documents the contract, no values)
!.env.example

# service-account / credential files
*service-account*.json
google-service-account*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase local
/supabase/.branches
/supabase/.temp
# edge function secrets (local serve) — never commit
/supabase/functions/.env
!/supabase/functions/.env.example
